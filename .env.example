# Kuzana Trendjack Hunter - Environment Variables

# ============================================
# Required: Thirdweb Web3 Configuration
# ============================================
# Get from https://thirdweb.com/team → Projects → Create Project
# Domain must include localhost and your production domain
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=c70944866bd556a711f59eb8e18fdd8a

# ============================================
# Required: Supabase Database Configuration
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# Optional: Social Media API Tokens
# ============================================
# Get from https://developer.twitter.com
X_BEARER_TOKEN=your_twitter_bearer_token_here

# Get from https://developers.facebook.com
META_ACCESS_TOKEN=your_instagram_business_token_here

# ============================================
# Optional: Media Extraction APIs
# ============================================
# Get from https://portal.azure.com (Azure Computer Vision)
# Or self-host: https://github.com/UB-Mannheim/tesseract
TESSERACT_API_KEY=your_ocr_api_key_here

# ============================================
# Optional: Error Monitoring (Sentry)
# ============================================
# Get from https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://your_key@sentry.io/your_project_id

# ============================================
# Deployment
# ============================================
NODE_ENV=production
